BOT_TOKEN=123456789:replace-with-your-token
ALLOWED_TELEGRAM_IDS=123456789
VPS_DISPLAY_NAME=My VPS

# Optional subscription integration.
SUB_TOKEN=change-me
SUB_BASE=https://example.com/subs/change-me
SUB_GENERATOR=/etc/proxy-subscription/generate.py

# Optional health checks and Cloudflare best-IP view.
CHECK_URLS=https://example.com/,https://panel.example.com/
CF_TEST_HOST=example.com

# Optional 3X-UI integration.
XUI_DB=/etc/x-ui/x-ui.db

# Monitor policy.
MONITOR_INTERVAL=600
DAILY_REPORT_HOUR=9
MEM_WARN_PERCENT=85
DISK_WARN_PERCENT=85
LOAD_WARN_PER_CORE=1.8
